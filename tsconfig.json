{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["ES2020", "ES2022.Error"],
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@substack-api": ["src/index"],
      "@substack-api/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "samples/**/*"]
}
