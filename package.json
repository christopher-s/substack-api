{
  "name": "substack-api",
  "version": "4.0.0",
  "description": "TypeScript API client for interacting with Substack webservice",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:watch": "jest --watch",
    "test:integration:watch": "jest --config jest.integration.config.js --watch",
    "test:e2e:watch": "jest --config jest.e2e.config.js --watch",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "prepare": "husky",
    "prepublishOnly": "pnpm lint && pnpm test",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts && pnpm format:check",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "sample": "pnpm exec ts-node -r tsconfig-paths/register samples/index.ts",
    "check-test-names": "./scripts/check-test-names.sh",
    "test:mutation": "stryker run",
    "test:unit:smoke": "jest --testNamePattern='\\[smoke\\]' --coverage=false",
    "test:unit:fast": "jest --testPathIgnorePatterns='live-api-validation|property'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christopher-s/substack-api.git"
  },
  "keywords": [
    "substack",
    "api",
    "client",
    "typescript"
  ],
  "author": "christopher-s",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/christopher-s/substack-api/issues"
  },
  "homepage": "https://github.com/christopher-s/substack-api#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/nock": "^11.1.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "dotenv": "^17.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-junit": "^17.0.0",
    "nock": "^14.0.13",
    "prettier": "^3.5.3",
    "rollup": "^4.55.1",
    "rollup-plugin-dts": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.14.0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "axios-rate-limit": "^1.4.0",
    "fp-ts": "^2.16.10",
    "io-ts": "^2.2.22"
  }
}
